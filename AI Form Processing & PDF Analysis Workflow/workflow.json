    {
      "parameters": {
        "jsCode": "const input = $json;\nconst answers = input[0] || input;  \n\nconst scoring = {\n  \"How are you\": { \n    \"good\": 10, \n    \"its okey\": 5, \n    \"not good\": 0 \n  },\n  \"Whay?\": { \n    \"i don't know\": 0, \n    \"i have a reason\": 5 \n  }\n};\n\nlet total = 0;\n\nfor (let q in scoring) {\n  const userAnswer = answers[q];\n  if (scoring[q] && scoring[q][userAnswer] !== undefined) {\n    total += scoring[q][userAnswer];\n  }\n}\n\nreturn [{\n  totalScore: total\n}];\n"
      },
