    {
      "parameters": {
        "jsCode": "// n8n Code node - Normalize multiple uploaded files into items with binary.file\n// Input: the form submission item (or items)\n// Output: one item per uploaded binary file with binary.file set\n\nconst outputs = [];\n\n// iterate over all incoming items (usually one submission)\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const formJson = item.json || {};\n  const binary = item.binary || {};\n\n  // collect binary property names\n  const binKeys = Object.keys(binary);\n\n  if (binKeys.length === 0) {\n    // no binary found: check if there is a JSON array of files (e.g., { data: [{url, name}, ...] })\n    if (Array.isArray(formJson.data) && formJson.data.length > 0) {\n      formJson.data.forEach((f, idx) => {\n        outputs.push({\n          json: {\n            formData: formJson,\n            originalName: f.name || f.filename || `file_${idx+1}`,\n            fileIndex: idx + 1,\n            totalFiles: formJson.data.length,\n            fileUrl: f.url || f.downloadUrl || null\n          }\n          // no binary attached here - add HTTP Request node after this to download file into binary.file\n        });\n      });\n      continue;\n    }\n\n    // fallback: keep one item so flow doesn't break\n    outputs.push({\n      json: {\n        formData: formJson,\n        originalName: 'no-binary-found',\n        fileIndex: 1,\n        totalFiles: 1\n      }\n    });\n    continue;\n  }\n\n  // If binary keys exist, create one output item per binary property\n  for (let k = 0; k < binKeys.length; k++) {\n    const key = binKeys[k];\n    const bin = binary[key];\n\n    // build new item with binary.file set (Extract node will look for 'file')\n    const out = {\n      json: {\n        formData: formJson,\n        originalName: bin.fileName || key || `file_${k+1}`,\n        originalBinaryKey: key,\n        fileIndex: k + 1,\n        totalFiles: binKeys.length\n      },\n      binary: {\n        // move whatever was in item.binary[key] into binary.file\n        file: bin\n      }\n    };\n\n    outputs.push(out);\n  }\n}\n\nreturn outputs;\n"
      },
      "type": "n8n-nodes-base.code",
